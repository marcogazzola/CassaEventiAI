<Application x:Class="CplCassaEventi.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CplCassaEventi.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters available in all windows -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
            <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>
            <conv:EuroConverter x:Key="Euro"/>
            <conv:InverseBoolConverter x:Key="InvBool"/>
            <conv:BoolToFirstRunLabelConverter x:Key="BoolToFirstRunLabel"/>
            <conv:BoolToNewEditLabelConverter x:Key="BoolToNewEditLabel"/>
            <conv:BoolToPwdLabelConverter x:Key="BoolToPwdLabel"/>
            <conv:HexToBrushConverter x:Key="HexBrush"/>
            <conv:HexToReadableForegroundConverter x:Key="HexForeground"/>
            <conv:EqualityMultiConverter x:Key="Equality"/>
            <conv:BoolToVoidLabelConverter x:Key="BoolToVoidLabel"/>
            <conv:BoolToVoidStyleConverter x:Key="BoolToVoidStyle"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
