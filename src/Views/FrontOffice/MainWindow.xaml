<Window x:Class="CplCassaEventi.Views.FrontOffice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CplCassaEventi.Converters"
        Title="CPL Cassa" WindowState="Maximized" MinWidth="1024" MinHeight="700">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>
        <conv:EuroConverter x:Key="Euro"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Background="{StaticResource BgPrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CPL Cassa" FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Source={x:Static Application.Current}, Path=CurrentSettings.ActiveEventName}"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⟳ Ristampa" Style="{StaticResource DeptTabButton}"
                            Command="{Binding ReprintLastCommand}"/>
                    <Button Content="✕ Storno" Style="{StaticResource DeptTabButton}"
                            Command="{Binding OpenVoidPanelCommand}"/>
                    <Button Content="⚙ BackOffice" Style="{StaticResource WarnButton}" Padding="10,5"
                            Click="OpenBackOffice_Click"/>
                    <Button Content="Chiudi turno" Style="{StaticResource DangerButton}" Padding="10,5"
                            Command="{Binding CloseShiftCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Dept tabs -->
        <Border Grid.Row="1" Background="{StaticResource BgPrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Margin="10,6">
                    <Button Content="Tutti" Style="{StaticResource DeptTabButton}" Margin="0,0,6,0"
                            Command="{Binding ClearDeptFilterCommand}"/>
                    <ItemsControl ItemsSource="{Binding Departments}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}" Style="{StaticResource DeptTabButton}"
                                        Command="{Binding DataContext.SelectDeptCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main area -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition Width="330"/>
            </Grid.ColumnDefinitions>

            <!-- Product grid -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0">
                <ItemsControl ItemsSource="{Binding FilteredProducts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="110" Height="76" Margin="4" Style="{StaticResource ProductButton}"
                                    Command="{Binding DataContext.AddProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               TextWrapping="Wrap" TextAlignment="Center"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Price, Converter={StaticResource Euro}}"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Center" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Cart panel -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="12,9"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5">
                        <Grid>
                            <TextBlock Text="Scontrino" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Button Content="Svuota" HorizontalAlignment="Right"
                                    Style="{StaticResource DangerButton}" Padding="8,3" FontSize="11"
                                    Command="{Binding ClearCartCommand}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CartItems}" Margin="10,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,0.5" Padding="0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="56"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding ProductName}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding UnitPrice, Converter={StaticResource Euro}}"
                                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0" VerticalAlignment="Center">
                                                <Button Content="−" Width="26" Height="26" Padding="0" Style="{StaticResource ProductButton}"
                                                        Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <TextBlock Text="{Binding Quantity}" Width="26" TextAlignment="Center"
                                                           VerticalAlignment="Center" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                                                <Button Content="+" Width="26" Height="26" Padding="0" Style="{StaticResource ProductButton}"
                                                        Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" TextAlignment="Right"
                                                       Text="{Binding LineTotal, Converter={StaticResource Euro}}"
                                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="10,8">
                        <!-- Sconto -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="72"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Sconto %" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBox Grid.Column="1" Height="30" Padding="6,0" VerticalContentAlignment="Center"
                                     Text="{Binding DiscountPct, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Metodi pagamento -->
                        <ItemsControl ItemsSource="{Binding PaymentMethods}" Margin="0,0,0,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Label}" Height="32" Margin="2,0"
                                            Style="{StaticResource DeptTabButton}" FontSize="12"
                                            Command="{Binding DataContext.SelectPaymentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Totale -->
                        <Border Background="{StaticResource AccentBlueBgBrush}" CornerRadius="8"
                                Padding="12,9" Margin="0,0,0,8">
                            <Grid>
                                <TextBlock Text="Totale" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBlueBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Total, Converter={StaticResource Euro}}"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlueBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Contanti + resto -->
                        <Border Background="{StaticResource BgSecondaryBrush}" CornerRadius="8"
                                Padding="10,8" Margin="0,0,0,8"
                                Visibility="{Binding ShowCashInput, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="96"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Contanti ricevuti" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Height="30" Padding="6,0" VerticalContentAlignment="Center"
                                             Text="{Binding CashGiven, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Resto" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Change, Converter={StaticResource Euro}}"
                                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Right"
                                               Foreground="{StaticResource AccentGreenBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Azioni -->
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="✓ Incassa e stampa"
                                    Style="{StaticResource SuccessButton}" Height="46" FontSize="15"
                                    Command="{Binding CheckoutCommand}"/>
                            <Button Grid.Column="2" Content="✕" Height="46"
                                    Style="{StaticResource DangerButton}" FontSize="18"
                                    Command="{Binding ClearCartCommand}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer stats -->
        <Border Grid.Row="3" Background="{StaticResource BgPrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0.5,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,7">
                    <TextBlock Text="{Binding SalesCount}" Style="{StaticResource FooterStatValue}"/>
                    <TextBlock Text="Scontrini" Style="{StaticResource FooterStatLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrush}" Width="0.5" Margin="16,8"/>
                <StackPanel Grid.Column="2" Margin="16,7"
                            Visibility="{Binding ShowTotalInFooter, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding TotalIncassato, Converter={StaticResource Euro}}"
                               Style="{StaticResource FooterStatValue}"
                               Foreground="{StaticResource AccentGreenBrush}"/>
                    <TextBlock Text="Totale incassato" Style="{StaticResource FooterStatLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="3" Fill="{StaticResource BorderBrush}" Width="0.5" Margin="0,8"
                           Visibility="{Binding ShowTotalInFooter, Converter={StaticResource BoolToVis}}"/>
                <StackPanel Grid.Column="4" Margin="16,7">
                    <TextBlock Text="{Binding LastOrderAmount, Converter={StaticResource Euro}}"
                               Style="{StaticResource FooterStatValue}"/>
                    <TextBlock Text="Ultimo ordine" Style="{StaticResource FooterStatLabel}"/>
                </StackPanel>
                <TextBlock Grid.Column="6" VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}" Text="{Binding StatusMessage}"/>
            </Grid>
        </Border>

        <!-- Void overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="4" Background="#80000000"
              Visibility="{Binding VoidPanelVisible, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource Card}" MaxWidth="400" MaxHeight="280"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Storno scontrino" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="Numero scontrino" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding VoidSaleIdText, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Padding="8,0" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Motivo storno" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding VoidReason, UpdateSourceTrigger=PropertyChanged}"
                             Height="36" Padding="8,0" Margin="0,0,0,16" VerticalContentAlignment="Center"/>

                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Annulla scontrino" Style="{StaticResource DangerButton}"
                                Height="40" Command="{Binding ConfirmVoidCommand}"/>
                        <Button Grid.Column="2" Content="Chiudi" Style="{StaticResource DeptTabButton}"
                                Height="40" Command="{Binding CloseVoidPanelCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
