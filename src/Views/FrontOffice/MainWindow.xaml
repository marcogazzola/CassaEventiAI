<Window x:Class="CassaEventiAI.Views.FrontOffice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CassaEventiAI.Converters"
        Title="CassaEventiAI" WindowState="Maximized" MinWidth="1100" MinHeight="700"
        Icon="/Resources/cassa.ico">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>
        <conv:EuroConverter x:Key="Euro"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgPrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CassaEventiAI" FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Source={x:Static Application.Current}, Path=CurrentSettings.ActiveEventName}"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding ConnectedUserName}"
                               HorizontalAlignment="Right" TextAlignment="Right"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ToolbarDateTime}"
                               HorizontalAlignment="Right" TextAlignment="Right"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,10,0" MinHeight="90">
                <ItemsControl ItemsSource="{Binding GroupedProducts}" MinHeight="180">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="5" Padding="12"  >
                                <StackPanel>
                                    <Border CornerRadius="8" Padding="8,4" Margin="0,0,0,8"
                                            Background="{Binding DepartmentColor, Converter={StaticResource HexBrush}, ConverterParameter=#378ADD}">
                                        <TextBlock Text="{Binding DepartmentName}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{Binding DepartmentColor, Converter={StaticResource HexForeground}, ConverterParameter=#378ADD}"/>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding Products}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="110" Height="76" Margin="4" Style="{StaticResource ProductButton}"
                                                        Command="{Binding DataContext.AddProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Tag="{Binding DataContext.DepartmentColor, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Background="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource HexBrush}, ConverterParameter=#1F2937}"
                                                        BorderBrush="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource HexBrush}, ConverterParameter=#4B5563}"
                                                        Foreground="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource HexForeground}, ConverterParameter=#1F2937}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                                   Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource HexForeground}, ConverterParameter=#1F2937}"/>
                                                        <TextBlock Text="{Binding Price, Converter={StaticResource Euro}}"
                                                                   FontSize="12" TextAlignment="Center" Margin="0,3,0,0"
                                                                   Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource HexForeground}, ConverterParameter=#1F2937}"/>
                                                        <TextBlock Text="{Binding StockQty, StringFormat='Stock: {0}'}"
                                                                   FontSize="9" TextAlignment="Center" Margin="0,2,0,0"
                                                                   Foreground="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource HexForeground}, ConverterParameter=#1F2937}"
                                                                   Visibility="{Binding TrackStock, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="12,9"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,0.5">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Scontrino" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <Border Background="{StaticResource AccentBlueBgBrush}" CornerRadius="10" Padding="7,2" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding CartQuantityCount}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBlueBrush}"/>
                                </Border>
                            </StackPanel>
                            <Button Content="Svuota" HorizontalAlignment="Right"
                                    Style="{StaticResource DangerButton}" Padding="8,3" FontSize="11"
                                    Command="{Binding ClearCartCommand}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CartItems}" Margin="10,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,0.5" Padding="0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="56"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding ProductName}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding UnitPrice, Converter={StaticResource Euro}}"
                                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0" VerticalAlignment="Center">
                                                <Button Content="−" Width="26" Height="26" Padding="0" Style="{StaticResource ProductButton}"
                                                        Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <TextBlock Text="{Binding Quantity}" Width="26" TextAlignment="Center"
                                                           VerticalAlignment="Center" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                                                <Button Content="+" Width="26" Height="26" Padding="0" Style="{StaticResource ProductButton}"
                                                        Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" TextAlignment="Right"
                                                       Text="{Binding LineTotal, Converter={StaticResource Euro}}"
                                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="10,8">
                        <Border Background="{StaticResource BgSecondaryBrush}" CornerRadius="8"
                                Padding="12,9" Margin="0,0,0,8">
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="82"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sconto %" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <Border Grid.Column="1" BorderThickness="0.5" BorderBrush="{StaticResource BorderBrush}">
                                    <TextBox Height="30" Padding="6,0" VerticalContentAlignment="Center"
                                         BorderThickness="0"
                                         PreviewTextInput="NumericTextBox_PreviewTextInput"
                                         DataObject.Pasting="NumericTextBox_Pasting"
                                         Text="{Binding DiscountPct, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalInput}}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource BgSecondaryBrush}" CornerRadius="8"
                                Padding="12,8" Margin="0,0,0,6"
                                Visibility="{Binding IsDiscountActive, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <TextBlock Text="{Binding DiscountPct, StringFormat='Sconto {0:F0}%'}"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DiscountAmount, StringFormat='-€ {0:F2}'}"
                                           FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"
                                           Foreground="{StaticResource AccentAmberBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource AccentBlueBgBrush}" CornerRadius="8"
                                Padding="12,9" Margin="0,0,0,8">
                            <Grid>
                                <TextBlock Text="Totale" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBlueBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Total, Converter={StaticResource Euro}}"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlueBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="8"
                                Padding="0" Margin="0,0,0,8">
                            <ItemsControl ItemsSource="{Binding PaymentMethods}" Margin="0,0,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Height="32" Margin="2,0" FontSize="12"
                                            Command="{Binding DataContext.SelectPaymentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                            <Button.Tag>
                                                <MultiBinding Converter="{StaticResource Equality}">
                                                    <Binding/>
                                                    <Binding Path="DataContext.SelectedPaymentMethod" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </Button.Tag>
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DeptTabButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentGreenBgBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="{Binding Label}" HorizontalAlignment="Center"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <Border Background="{StaticResource BgSecondaryBrush}" CornerRadius="8"
                                Padding="10,8" Margin="0,0,0,8"
                                Visibility="{Binding ShowCashInput, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="96"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Contanti ricevuti" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Height="30" Padding="6,0" VerticalContentAlignment="Center"
                                             PreviewTextInput="NumericTextBox_PreviewTextInput"
                                             DataObject.Pasting="NumericTextBox_Pasting"
                                             Text="{Binding CashGiven, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Resto" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Change, Converter={StaticResource Euro}}"
                                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Right"
                                               Foreground="{StaticResource AccentGreenBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Button Content="✓ Incassa e stampa"
                                Style="{StaticResource SuccessButton}" Height="46" FontSize="15"
                                Command="{Binding CheckoutCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource BgPrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0.5,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="16,7" Background="Transparent"
                            MouseLeftButtonDown="SalesCount_Click">
                    <TextBlock Text="{Binding SalesCount}" Style="{StaticResource FooterStatValue}"/>
                    <TextBlock Text="Scontrini" Style="{StaticResource FooterStatLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrush}" Width="0.5" Margin="0,8"
                           Visibility="{Binding ShowTotalInFooter, Converter={StaticResource BoolToVis}}"/>
                <StackPanel Grid.Column="2" Margin="16,7"
                           Visibility="{Binding ShowTotalInFooter, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding TotalIncassato, Converter={StaticResource Euro}}"
                              Style="{StaticResource FooterStatValue}"
                              Foreground="{StaticResource AccentGreenBrush}"/>
                    <TextBlock Text="Totale incassato" Style="{StaticResource FooterStatLabel}"/>
                </StackPanel>
                <Rectangle Grid.Column="3" Fill="{StaticResource BorderBrush}" Width="0.5" Margin="0,8"
                           Visibility="{Binding ShowTotalInFooter, Converter={StaticResource BoolToVis}}"/>
                <StackPanel Grid.Column="4" Margin="16,7">
                    <TextBlock Text="{Binding LastOrderAmount, Converter={StaticResource Euro}}"
                              Style="{StaticResource FooterStatValue}"/>
                    <TextBlock Text="Ultimo ordine" Style="{StaticResource FooterStatLabel}"/>
                </StackPanel>
                <TextBlock Grid.Column="7" VerticalAlignment="Center" FontSize="12" HorizontalAlignment="Right" TextAlignment="Right" Margin="16,0,8,0"
                           Foreground="{StaticResource TextMutedBrush}" Text="{Binding StatusMessage}"/>
                <Button Grid.Column="8" Content="🔍" ToolTip="Anteprima scontrino"
                        Style="{StaticResource DeptTabButton}" Padding="10,4" Margin="0,6,12,6"
                        Command="{Binding PreviewCurrentReceiptCommand}"/>

            </Grid>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource BgPrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0.5,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="♻ Ristampa ultimo scontrino" Style="{StaticResource SuccessButton}" Padding="10,5" Margin="0,0,8,0"
                           Command="{Binding ReprintLastCommand}"/>
                    <Button Content="↩ Storno" Style="{StaticResource WarnButton}" Padding="10,5"
                           Command="{Binding OpenVoidPanelCommand}"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="MarcoGazzola.com © 2026"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📊 Reportistica" Style="{StaticResource WarnButton}" Padding="10,5" Margin="0,0,8,0"
                           Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                           Click="OpenReports_Click"/>
                    <Button Content="⚙ Settings" Style="{StaticResource WarnButton}" Padding="10,5" Margin="0,0,8,0"
                           Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                           Click="OpenBackOffice_Click"/>
                    <Button Content="✕ Chiudi turno" Style="{StaticResource DangerButton}" Padding="10,5"
                           Command="{Binding CloseShiftCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="0" Grid.RowSpan="4" Background="#80000000"
              Visibility="{Binding VoidPanelVisible, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource Card}" Width="620" MaxHeight="560"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Storno scontrino" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Height="34" Padding="8,0" VerticalContentAlignment="Center"
                                 Text="{Binding VoidSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="Cerca" Style="{StaticResource PrimaryButton}" Padding="12,6"
                                Command="{Binding SearchVoidSalesCommand}"/>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding VoidSearchResults}"
                              SelectedItem="{Binding SelectedVoidSale}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Scontrino" Binding="{Binding SaleId}" Width="80"/>
                            <DataGridTextColumn Header="Data/Ora" Width="140"
                                                Binding="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"/>
                            <DataGridTextColumn Header="Operatore" Binding="{Binding OperatorName}" Width="*"/>
                            <DataGridTextColumn Header="Totale" Width="90"
                                                Binding="{Binding Total, StringFormat='€ {0:F2}'}"/>
                            <DataGridCheckBoxColumn Header="Stornato" Binding="{Binding IsVoided, Mode=OneWay}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Margin="0,12,0,0">
                        <TextBlock Text="Motivo" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding VoidReason, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34" Padding="8,0" Margin="0,0,0,10" VerticalContentAlignment="Center"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="{Binding SelectedVoidSale.IsVoided, Converter={StaticResource BoolToVoidLabel}}" 
                                    Height="40" Command="{Binding ConfirmVoidCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DeptTabButton}">
                                        <Setter Property="Background" Value="{StaticResource AccentRedBgBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedVoidSale.IsVoided}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentGreenBgBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Grid.Column="2" Content="Chiudi" Style="{StaticResource DeptTabButton}"
                                    Background="{StaticResource BgPrimaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Height="40" Command="{Binding CloseVoidPanelCommand}"/>
                        </Grid>
                    </StackPanel>
                    <TextBlock Grid.Row="4" Text="MarcoGazzola.com © 2026"
                               HorizontalAlignment="Center" Margin="0,10,0,0"
                               FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
