<Window x:Class="CplCassaEventi.Views.Reports.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CplCassaEventi.Converters"
        Title="Reportistica" Height="760" Width="1080"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <conv:EuroConverter x:Key="Euro"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Da" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <DatePicker SelectedDate="{Binding FromDate}" Width="140"/>
                <TextBlock Text="A" VerticalAlignment="Center" Margin="14,0,8,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <DatePicker SelectedDate="{Binding ToDate}" Width="140"/>
                <Button Content="Aggiorna" Margin="10,0,0,0" Style="{StaticResource PrimaryButton}"
                        Command="{Binding RefreshCommand}"/>
                <Button Content="Export Excel" Margin="8,0,0,0" Style="{StaticResource SuccessButton}"
                        Command="{Binding ExportExcelCommand}"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Incasso alla data">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Margin="0,0,0,10">
                        <Border Style="{StaticResource Card}" Margin="0,0,10,0" Width="180">
                            <StackPanel>
                                <TextBlock Text="Scontrini emessi" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding IssuedReceipts}" FontSize="28" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,10,0" Width="180">
                            <StackPanel>
                                <TextBlock Text="Scontrini annullati" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding VoidedReceipts}" FontSize="28" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Width="220">
                            <StackPanel>
                                <TextBlock Text="Totale venduto" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding TotalSold, Converter={StaticResource Euro}}" FontSize="28" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding DailyProducts}" AutoGenerateColumns="False"
                              IsReadOnly="True" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Prodotto" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Quantità" Binding="{Binding Quantity}" Width="90"/>
                            <DataGridTextColumn Header="Importo totale" Width="120"
                                                Binding="{Binding TotalAmount, StringFormat='€ {0:F2}'}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Ordini emessi alla data">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <DataGrid Grid.Column="0" ItemsSource="{Binding DailyOrders}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding SaleId}" Width="55"/>
                            <DataGridTextColumn Header="Data/Ora" Width="135"
                                                Binding="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"/>
                            <DataGridTextColumn Header="Operatore" Binding="{Binding OperatorName}" Width="*"/>
                            <DataGridTextColumn Header="Pagamento" Binding="{Binding PaymentMethod}" Width="105"/>
                            <DataGridTextColumn Header="Totale" Width="90"
                                                Binding="{Binding Total, StringFormat='€ {0:F2}'}"/>
                            <DataGridCheckBoxColumn Header="Annullato" Binding="{Binding IsVoided}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="140"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Dettaglio ordine" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedOrderItems}" AutoGenerateColumns="False"
                                      IsReadOnly="True" Background="Transparent">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Articolo" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="Qta" Binding="{Binding Quantity}" Width="45"/>
                                    <DataGridTextColumn Header="Tot." Binding="{Binding LineTotal, StringFormat='€ {0:F2}'}" Width="75"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Grid.Row="2" Text="Anteprima scontrino" FontSize="12" Margin="0,8,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Grid.Row="3" Text="{Binding SelectedOrderPreview}" IsReadOnly="True"
                                     FontFamily="Consolas" FontSize="12"
                                     TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                            <Button Grid.Row="4" Content="Stampa anteprima" Margin="0,8,0,0"
                                    HorizontalAlignment="Right" Style="{StaticResource DeptTabButton}"
                                    Command="{Binding PrintSelectedPreviewCommand}"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
