<Window x:Class="CplCassaEventi.Views.Shared.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CplCassaEventi.Converters"
        Title="Accesso Operatore" Height="440" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed"/>
    </Window.Resources>
    <Grid VerticalAlignment="Center" Margin="36">

        <!-- Normal login -->
        <Border Style="{StaticResource Card}"
                Visibility="{Binding MustChangePassword, Converter={StaticResource InvBoolToVis}}">
            <StackPanel>
                <TextBlock Text="Accesso operatore" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Source={x:Static Application.Current},
                           Path=CurrentSettings.ActiveEventName, StringFormat='Evento: {0}'}"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                <TextBlock Text="Username" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameBox" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Height="38" Padding="10,0" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Password" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Height="38" Padding="10,0" Margin="0,0,0,8"  VerticalContentAlignment="Center"
                             PasswordChanged="PwdBox_PasswordChanged"/>

                <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                           Foreground="{StaticResource AccentRedBrush}" Margin="0,0,0,12"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}"
                           TextWrapping="Wrap"/>

                <Button Content="Accedi" Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}" IsDefault="True" Height="40"/>
            </StackPanel>
        </Border>

        <!-- Force password change -->
        <Border Style="{StaticResource Card}"
                Visibility="{Binding MustChangePassword, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Cambia password" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock FontSize="12" Foreground="{StaticResource AccentAmberBrush}" Margin="0,0,0,16"
                           TextWrapping="Wrap"
                           Text="È necessario impostare una nuova password prima di procedere."/>

                <TextBlock Text="Nuova password" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="NewPwdBox" Height="38" Padding="10,0" Margin="0,0,0,10"
                             VerticalContentAlignment="Center"
                             PasswordChanged="NewPwdBox_PasswordChanged"/>

                <TextBlock Text="Conferma password" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="ConfirmPwdBox" Height="38" Padding="10,0" Margin="0,0,0,8"
                             VerticalContentAlignment="Center"
                             PasswordChanged="ConfirmPwdBox_PasswordChanged"/>

                <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                           Foreground="{StaticResource AccentRedBrush}" Margin="0,0,0,10"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}"
                           TextWrapping="Wrap"/>

                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Salva e accedi"
                            Style="{StaticResource PrimaryButton}" Height="40"
                            Command="{Binding ConfirmPasswordChangeCommand}"/>
                    <Button Grid.Column="2" Content="Annulla" Width="80" Height="40"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding CancelPasswordChangeCommand}"/>
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</Window>
