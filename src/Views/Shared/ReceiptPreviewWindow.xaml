<Window x:Class="CassaEventiAI.Views.Shared.ReceiptPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anteprima scontrino" Height="620" Width="460"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBox x:Name="PreviewText"
                 Grid.Row="0"
                 IsReadOnly="True"
                 FontFamily="Consolas"
                 FontSize="13"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"/>
        <Button Grid.Row="1" Content="Chiudi" Width="90" Height="34"
                Margin="0,10,0,0"
                HorizontalAlignment="Right"
                Click="Close_Click"/>
    </Grid>
</Window>
