<Window x:Class="CassaEventiAI.Views.Shared.OrderSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Riepilogo ordine" Height="520" Width="430"
        WindowStartupLocation="CenterOwner"
        Icon="/Resources/cassa.ico"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titolo -->
        <TextBlock x:Name="TitleBlock" Grid.Row="0" FontSize="18" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,3"/>
        <TextBlock x:Name="SubtitleBlock" Grid.Row="1" FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

        <!-- Articoli -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,10">
            <DataGrid x:Name="ItemsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="Transparent" HeadersVisibility="Column"
                      BorderThickness="0" GridLinesVisibility="None"
                      CanUserResizeColumns="False" CanUserSortColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Q.tà" Binding="{Binding Quantity}" Width="45"/>
                    <DataGridTextColumn Header="Articolo" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Totale" Width="80"
                                        Binding="{Binding LineTotal, StringFormat='€ \{0:F2\}'}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Totale -->
        <Border Grid.Row="3" Background="{StaticResource BgSecondaryBrush}" CornerRadius="6"
                Padding="12,8" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="TOTALE" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TotalBlock" Grid.Column="1" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Pagamento -->
        <TextBlock x:Name="PaymentBlock" Grid.Row="4" FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,14"/>

        <!-- Pulsanti -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Ristampa scontrino"
                    Style="{StaticResource PrimaryButton}" Height="38" Click="Reprint_Click"/>
            <Button Grid.Column="2" Content="Chiudi" Style="{StaticResource SuccessButton}"
                    Height="38" Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
