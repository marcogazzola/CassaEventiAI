<Window x:Class="CassaEventiAI.Views.Shared.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cassa Eventi AI" Height="620" Width="540"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Icon="/Resources/cassa.ico">
    <Grid>
    <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
      <Grid Margin="36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="Cassa Eventi AI" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding AppVersion}" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom"/>
            </Grid>
            <TextBlock Text="Gestione cassa eventi"
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            <Border Background="#1E3A8A" CornerRadius="4" Padding="10,6" Margin="0,8,0,0"
                    Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding UpdateStatusText}" FontSize="12"
                           Foreground="White" FontWeight="SemiBold"/>
            </Border>
        </StackPanel>

        <!-- Evento attivo -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12"
                Visibility="{Binding HasActiveEvent, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Evento in corso" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding ActiveEventName}" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                <Button Content="Continua con questo evento →"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ContinueWithActiveEventCommand}"/>
            </StackPanel>
        </Border>

        <!-- Setup primo avvio: crea admin + evento -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="{Binding IsFirstRun, Converter={StaticResource BoolToFirstRunLabel}}"/>

                <!-- Admin setup (solo primo avvio) -->
                <StackPanel Visibility="{Binding IsFirstRun, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Crea account amministratore" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Username" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBox Grid.Column="1" Height="32" Padding="8,0" VerticalContentAlignment="Center"
                                 Text="{Binding AdminUsername, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Nome visualizzato" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBox Grid.Column="1" Height="32" Padding="8,0" VerticalContentAlignment="Center"
                                 Text="{Binding AdminDisplayName, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Password" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <PasswordBox x:Name="AdminPwdBox" Grid.Column="1" Height="32" Padding="8,0"
                                     VerticalContentAlignment="Center"
                                     PasswordChanged="AdminPwdBox_PasswordChanged"/>
                    </Grid>
                    <Separator Margin="0,0,0,10"/>
                </StackPanel>

                <!-- Nome evento -->
                <TextBlock Text="Nome evento" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Height="36" Padding="8,0" Margin="0,0,8,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding NewEventName, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="1" Content="Crea e avvia"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CreateAndStartCommand}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Archivio eventi -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Riapri evento archiviato" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <ListBox ItemsSource="{Binding ArchivedEvents}" MaxHeight="160"
                         Background="Transparent" BorderThickness="0"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgSecondaryBrush}"
                                    CornerRadius="6" Padding="10,7" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel >
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Riapri"
                                            Style="{StaticResource PrimaryButton}" Padding="10,5"
                                            Command="{Binding DataContext.OpenArchivedCommand,
                                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
      </Grid>
    </ScrollViewer>
    <TextBlock Grid.Row="1" Text="MarcoGazzola.com © 2026"
               HorizontalAlignment="Center" Margin="0,6,0,10"
               FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
    </Grid>
</Window>
